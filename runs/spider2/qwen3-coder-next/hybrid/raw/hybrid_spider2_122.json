      "sql": "SELECT de.full_name\nFROM drivers_ext de\nJOIN lap_positions lp ON de.driver_id = lp.driver_id\nLEFT JOIN retirements ret ON lp.race_id = ret.race_id AND lp.driver_id = ret.driver_id\nLEFT JOIN pit_stops ps ON lp.race_id = ps.race_id AND lp.driver_id = ps.driver_id\nWHERE lp.lap > 1\n  AND (lp.lap_type != 'pit_entry' OR lp.lap_type != 'pit_exit')\n  AND ret.race_id IS NULL\n  AND ps.race_id IS NULL\nGROUP BY de.driver_id, de.full_name\nHAVING \n  SUM(CASE WHEN lp.position > LAG(lp.position) OVER (PARTITION BY de.driver_id, lp.race_id ORDER BY lp.lap) THEN 1 ELSE 0 END) >\n  SUM(CASE WHEN lp.position < LAG(lp.position) OVER (PARTITION BY de.driver_id, lp.race_id ORDER BY lp.lap) THEN 1 ELSE 0 END)",
