      "sql": "SELECT \n    hd_buy_potential,\n    CASE \n        WHEN ss_sold_date_sk IS NOT NULL THEN 'Store'\n        WHEN ws_sold_date_sk IS NOT NULL THEN 'Web'\n        WHEN cs_sold_date_sk IS NOT NULL THEN 'Catalog'\n    END AS sales_channel,\n    SUM(COALESCE(ss_ext_sales_price, 0)) AS store_sales_total,\n    SUM(COALESCE(ws_ext_sales_price, 0)) AS web_sales_total,\n    SUM(COALESCE(cs_ext_sales_price, 0)) AS catalog_sales_total\nFROM \n    store_sales\n    JOIN date_dim ON store_sales.ss_sold_date_sk = date_dim.d_date_sk\n    JOIN customer ON store_sales.ss_customer_sk = customer.c_customer_sk\n    JOIN household_demographics ON customer.c_current_hdemo_sk = household_demographics.hd_demo_sk\nWHERE \n    date_dim.d_date >= '1999-02-22' AND date_dim.d_date <= '1999-03-24'\nGROUP BY \n    hd_buy_potential,\n    CASE \n        WHEN ss_sold_date_sk IS NOT NULL THEN 'Store'\n        WHEN ws_sold_date_sk IS NOT NULL THEN 'Web'\n        WHEN cs_sold_date_sk IS NOT NULL THEN 'Catalog'\n    END\nORDER BY \n    hd_buy_potential,\n    sales_channel;",
